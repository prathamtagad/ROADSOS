rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /incidents/{incidentId} {
      allow read, create, update: if isSignedIn();
      allow delete: if false;
    }

    // Contacts are public-read, but only admin/Cloud Functions can write
    match /contacts/{contactId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // Hazards: any user can report (create) and read, but not delete/edit others'
    match /hazards/{hazardId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // Data quality is system-managed only
    match /dataQuality/{country} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // Border geofences are system-managed only
    match /borderGeofences/{countryPair} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /errors/{errorId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }
  }
}

